{
  "record_type": "orchestration_default",
  "default_mode": "workflow",
  "solo_requires_named_exception": true,
  "solo_exceptions": [
    "conversational-reply",
    "single-read-lookup",
    "trivial-mechanical-edit",
    "emergency-transport-recovery"
  ],
  "decomposition": "beads-formula",
  "dispatch": "mesh wave dispatch",
  "close_policy": "prose-summary",
  "closeout": {
    "predicate_status": "green",
    "result_envelope_required": true,
    "rollout": {
      "mode": "adoption",
      "evidence": [
        {
          "kind": "beads",
          "label": "rollout adopted",
          "ref": "cue-first-feature rollout step closed with adoption evidence"
        }
      ]
    }
  },
  "bounded": true,
  "feature_formula": "cue-first-feature",
  "review_formula": "review-wave",
  "verdict_formula": "judge-panel",
  "convergence_formula": "loop-until-dry",
  "closing_formula": "completeness-critic"
}
