{
  "command": "mesh watch",
  "output_mode": "json",
  "once": true,
  "include_detached": false,
  "interval_seconds": 2,
  "idle_threshold_seconds": 30,
  "mesh_root": "/workspace",
  "kitty_context": {
    "record_type": "kitty_context_resolution",
    "source": "mesh-root-config",
    "mesh_root": "/workspace",
    "cwd": "/workspace/codex-mesh",
    "kitty_listen_on": "unix:/tmp/codex-mesh-lab",
    "config_path": "/home/galeavenworth/.config/codex-mesh/contexts.json"
  },
  "workspace_scan_depth": 1
}
