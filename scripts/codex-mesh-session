#!/usr/bin/env python3
import argparse
import json
import os
import shlex
import subprocess
import sys
import time


VALID_PROFILES = ("operator",)


def die(message):
    print(f"codex-mesh-session: {message}", file=sys.stderr)
    sys.exit(2)


def script_dir():
    return os.path.dirname(os.path.realpath(__file__))


def generated_at():
    if os.environ.get("CODEX_MESH_NOW"):
        try:
            return int(float(os.environ["CODEX_MESH_NOW"]))
        except ValueError:
            die("CODEX_MESH_NOW must be a Unix timestamp")
    return int(time.time())


def load_json(path):
    try:
        with open(path, encoding="utf-8") as handle:
            return json.load(handle)
    except OSError as exc:
        die(f"could not read watch snapshot {path}: {exc}")
    except json.JSONDecodeError as exc:
        die(f"watch snapshot is not valid JSON: {exc}")


def live_watch_snapshot(mesh_root):
    command = [os.path.join(script_dir(), "mesh"), "watch", "--once", "--json"]
    if mesh_root:
        command.extend(["--mesh-root", mesh_root])
    completed = subprocess.run(
        command,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if completed.returncode != 0:
        message = (completed.stderr or completed.stdout or "mesh watch failed").strip()
        die(message)
    try:
        return json.loads(completed.stdout)
    except json.JSONDecodeError as exc:
        die(f"mesh watch returned invalid JSON: {exc}")


def validate_snapshot(snapshot):
    if not isinstance(snapshot, dict):
        die("watch snapshot must be a JSON object")
    if snapshot.get("record_type") != "watch_snapshot":
        die("watch snapshot record_type must be watch_snapshot")
    if not isinstance(snapshot.get("workspaces"), list):
        die("watch snapshot workspaces must be an array")
    if not isinstance(snapshot.get("summary"), dict):
        die("watch snapshot summary must be an object")
    return snapshot


def quote(value):
    return shlex.quote(str(value))


def mesh_root_from_snapshot(snapshot):
    if snapshot.get("mesh_root"):
        return snapshot["mesh_root"]
    for workspace in snapshot.get("workspaces", []):
        if workspace.get("workspace_role") == "mesh-root":
            return workspace.get("root")
    return os.getcwd()


def live_agent_count(snapshot):
    summary = snapshot.get("summary", {})
    return int(summary.get("active", 0)) + int(summary.get("quiet", 0)) + int(summary.get("orphan", 0))


def workspace_sort_key(workspace):
    role_rank = 0 if workspace.get("workspace_role") == "mesh-root" else 1
    return (role_rank, workspace.get("name", ""), workspace.get("root", ""))


def render_operator_lines(snapshot):
    mesh_root = mesh_root_from_snapshot(snapshot)
    generated = snapshot.get("generated_at_unix", "unknown")
    workspaces = sorted(snapshot.get("workspaces", []), key=workspace_sort_key)
    watch = f"mesh watch --mesh-root {quote(mesh_root)}; exec \"$SHELL\" -l"
    watch_once = f"mesh watch --once --include-detached --mesh-root {quote(mesh_root)}; exec \"$SHELL\" -l"
    lines = [
        "# Generated by codex-mesh: mesh session render --profile operator",
        f"# Source: mesh watch snapshot generated_at_unix={generated}",
        "# Operator scaffolding only: no addressed agents are relaunched and no live user vars are stored.",
        "new_tab mesh",
        "layout vertical",
        f"cd {quote(mesh_root)}",
        f"launch --title mesh-watch sh -lc {quote(watch)}",
        f"launch --title mesh-once sh -lc {quote(watch_once)}",
    ]

    for workspace in workspaces:
        root = workspace.get("root")
        name = workspace.get("name")
        if not root or not name:
            continue
        beads = workspace.get("beads_status", "unknown")
        tasks = workspace.get("task_count", 0)
        lines.extend(
            [
                f"# workspace {name}: beads={beads} tasks={tasks}",
                f"new_tab {quote(name)}",
                "layout vertical",
                f"cd {quote(root)}",
                f"launch --title {quote(name + '-shell')}",
            ]
        )
    return lines


def render_payload(args, snapshot):
    lines = render_operator_lines(snapshot)
    content = "\n".join(lines) + "\n"
    command = {
        "command": "mesh session render",
        "profile": args.profile,
        "output_mode": "json" if args.json else "session",
        "source": "watch-snapshot",
        "workspace_scan_depth": 1,
    }
    if args.mesh_root:
        command["mesh_root"] = os.path.abspath(args.mesh_root)
    if args.watch_snapshot:
        command["watch_snapshot"] = os.path.abspath(args.watch_snapshot)
    if args.output:
        command["output_path"] = os.path.abspath(args.output)

    return {
        "record_type": "kitty_session_render",
        "profile": args.profile,
        "source": "watch-snapshot",
        "command": command,
        "generated_at_unix": generated_at(),
        "source_snapshot": snapshot,
        "session_file": {
            "extension": ".kitty-session",
            "lines": lines,
            "content": content,
        },
        "rendered_workspace_count": len(snapshot.get("workspaces", [])),
        "rendered_agent_count": live_agent_count(snapshot),
        "rendering_policy": {
            "operator_scaffolding_only": True,
            "relaunches_agents": False,
            "stores_live_agent_state": False,
            "writes_durable_state": False,
            "uses_codex_user_vars": False,
            "session_file_keywords": ["new_tab", "layout", "cd", "launch"],
        },
    }


def do_render(args):
    if args.profile not in VALID_PROFILES:
        die(f"unsupported profile: {args.profile}")
    if args.output and not args.output.endswith(".kitty-session"):
        die("--output must end with .kitty-session")

    snapshot = validate_snapshot(load_json(args.watch_snapshot) if args.watch_snapshot else live_watch_snapshot(args.mesh_root))
    payload = render_payload(args, snapshot)
    content = payload["session_file"]["content"]

    if args.output:
        with open(args.output, "w", encoding="utf-8") as handle:
            handle.write(content)

    if args.json:
        json.dump(payload, sys.stdout, indent=2, sort_keys=True)
        print()
    elif not args.output:
        sys.stdout.write(content)
    else:
        print(os.path.abspath(args.output))


def main():
    parser = argparse.ArgumentParser(description="Render codex-mesh kitty session files")
    subparsers = parser.add_subparsers(dest="command", required=True)

    render_parser = subparsers.add_parser("render", description="render an operator .kitty-session file")
    render_parser.add_argument("--profile", default="operator", choices=VALID_PROFILES)
    render_parser.add_argument("--mesh-root", help="mesh root used for live watch snapshots")
    render_parser.add_argument("--watch-snapshot", help="fixture #WatchSnapshot JSON to render instead of querying live state")
    render_parser.add_argument("--output", help="write rendered .kitty-session file to this path")
    render_parser.add_argument("--json", action="store_true", help="emit #KittySessionRender JSON instead of session text")
    render_parser.set_defaults(func=do_render)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
