#!/usr/bin/env python3
import fcntl
import json
import os
import pty
import select
import signal
import shutil
import sys
import termios
import tty
import subprocess
import time


def die(message):
    print(message, file=sys.stderr)
    return 2


def copy_winsize(master_fd, source_fd):
    try:
        size = fcntl.ioctl(source_fd, termios.TIOCGWINSZ, b"\0" * 8)
        fcntl.ioctl(master_fd, termios.TIOCSWINSZ, size)
    except OSError:
        pass


def status_to_exit(status):
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


def resolve_session_id():
    explicit = os.environ.get("CODEX_MESH_SESSION_ID")
    if explicit and explicit.isdigit() and int(explicit) > 0:
        return explicit

    window_id = os.environ.get("KITTY_WINDOW_ID")
    if window_id and window_id.isdigit() and int(window_id) > 0:
        return window_id

    addr = os.environ.get("CODEX_ADDR")
    if not addr or shutil.which("kitty") is None:
        return str(os.getpid())

    for _ in range(20):
        try:
            result = subprocess.run(
                ["kitty", "@", "ls"],
                check=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                timeout=1,
                text=True,
            )
            windows = []
            for os_window in json.loads(result.stdout):
                for tab in os_window.get("tabs", []):
                    for window in tab.get("windows", []):
                        if window.get("user_vars", {}).get("codex_addr") == addr:
                            windows.append(window)
            if len(windows) == 1:
                return str(windows[0]["id"])
        except (OSError, subprocess.SubprocessError, json.JSONDecodeError, KeyError):
            pass
        time.sleep(0.05)

    return str(os.getpid())


def set_window_vars(session_id, transcript_path):
    if not session_id.isdigit() or shutil.which("kitty") is None:
        return
    try:
        subprocess.run(
            [
                "kitty",
                "@",
                "set-user-vars",
                "--match",
                f"id:{session_id}",
                f"codex_session={session_id}",
                f"codex_transcript={transcript_path}",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=1,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        pass


def main():
    if len(sys.argv) < 3:
        return die("usage: codex-mesh-record TRANSCRIPT_DIR COMMAND [ARG...]")

    transcript_dir = sys.argv[1]
    command = sys.argv[2:]

    os.makedirs(transcript_dir, mode=0o700, exist_ok=True)
    os.chmod(transcript_dir, 0o700)
    session_id = resolve_session_id()
    transcript_path = os.path.join(transcript_dir, f"{session_id}.ansi")
    os.environ["CODEX_MESH_SESSION_ID"] = session_id
    os.environ["CODEX_MESH_TRANSCRIPT"] = transcript_path
    if os.environ.get("CODEX_MESH_RECORD_SET_KITTY_VARS") != "0":
        set_window_vars(session_id, transcript_path)

    pid, master_fd = pty.fork()
    if pid == 0:
        os.execvp(command[0], command)

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    stdin_is_tty = os.isatty(stdin_fd)
    old_attrs = None
    stdin_open = True

    if stdin_is_tty:
        old_attrs = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)
        copy_winsize(master_fd, stdin_fd)

        def resize(_signum, _frame):
            copy_winsize(master_fd, stdin_fd)

        signal.signal(signal.SIGWINCH, resize)

    exit_status = 1
    try:
        transcript_fd = os.open(transcript_path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(transcript_fd, "wb", buffering=0) as transcript:
            while True:
                read_fds = [master_fd]
                if stdin_open:
                    read_fds.append(stdin_fd)

                ready, _, _ = select.select(read_fds, [], [])

                if master_fd in ready:
                    try:
                        data = os.read(master_fd, 65536)
                    except OSError:
                        break
                    if not data:
                        break
                    os.write(stdout_fd, data)
                    transcript.write(data)

                if stdin_open and stdin_fd in ready:
                    try:
                        data = os.read(stdin_fd, 65536)
                    except OSError:
                        stdin_open = False
                        continue
                    if data:
                        os.write(master_fd, data)
                    else:
                        stdin_open = False

        _, status = os.waitpid(pid, 0)
        exit_status = status_to_exit(status)
    finally:
        if old_attrs is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_attrs)
        try:
            os.close(master_fd)
        except OSError:
            pass

    return exit_status


if __name__ == "__main__":
    sys.exit(main())
