#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
import time


BEADS_ISSUE_RE = re.compile(r"^[a-z][a-z0-9]*-[a-z0-9]+(-[a-z0-9]+)*(\.[0-9]+)*$")
ADDR_RE = re.compile(r"^[a-z][a-z0-9-]{1,63}$")
COOKBOOK_ROLES = ("implementation", "reviewer", "judge", "probe")
FRONTIER_COMMAND = "bd ready --parent <epic> --exclude-type epic --json"


def die(message):
    print(f"codex-mesh-wave: {message}", file=sys.stderr)
    sys.exit(2)


def script_dir():
    return os.path.dirname(os.path.realpath(__file__))


def load_json(path):
    try:
        with open(path, encoding="utf-8") as handle:
            return json.load(handle)
    except OSError as exc:
        die(f"could not read {path}: {exc}")
    except json.JSONDecodeError as exc:
        die(f"{path} is not valid JSON: {exc}")


def validate_issue_id(value, field):
    if not isinstance(value, str) or not BEADS_ISSUE_RE.match(value):
        die(f"{field} must be a Beads issue id")
    return value


def validate_address(value, field):
    if not isinstance(value, str) or not ADDR_RE.match(value):
        die(f"{field} must be a codex-mesh address")
    return value


def validate_abs_path(value, field):
    if not isinstance(value, str) or not os.path.isabs(value):
        die(f"{field} must be an absolute path")
    return value


def validate_request(request):
    if not isinstance(request, dict):
        die("request must be a JSON object")
    if request.get("record_type") != "wave_request":
        die("request record_type must be wave_request")

    validate_issue_id(request.get("epic"), "request.epic")
    role = request.get("role")
    if not isinstance(role, str) or not re.match(r"^[a-z][a-z0-9-]{1,31}$", role):
        die("request.role must be a codex-mesh role")
    validate_address(request.get("address_prefix"), "request.address_prefix")

    cap = request.get("concurrency_cap")
    if not isinstance(cap, int) or cap <= 0:
        die("request.concurrency_cap must be a positive integer")
    workdir = request.get("workdir")
    if not isinstance(workdir, str) or not os.path.isabs(workdir):
        die("request.workdir must be an absolute path")
    if request.get("prompt_mode") != "goal-first":
        die("request.prompt_mode must be goal-first")
    template = request.get("message_template")
    if not isinstance(template, str) or not template.startswith("/goal "):
        die("request.message_template must start with /goal")
    if request.get("frontier_command", FRONTIER_COMMAND) != FRONTIER_COMMAND:
        die(f"request.frontier_command must be {FRONTIER_COMMAND}")
    request["frontier_command"] = FRONTIER_COMMAND
    request["dry_run"] = bool(request.get("dry_run", False))
    request["mutating"] = bool(request.get("mutating", False))
    isolation = request.get("isolation") or {"mode": "none"}
    if not isinstance(isolation, dict):
        die("request.isolation must be an object")
    mode = isolation.get("mode")
    if mode not in ("none", "worktree"):
        die("request.isolation.mode must be none or worktree")
    if mode == "none":
        if any(key in isolation for key in ("worktree_base", "worktree_path", "cleanup")):
            die("request.isolation mode none cannot set worktree fields")
    if mode == "worktree":
        base = isolation.get("worktree_base")
        if not isinstance(base, str) or not os.path.isabs(base):
            die("request.isolation.worktree_base must be an absolute path")
        cleanup = isolation.get("cleanup", "remove-if-unchanged")
        if cleanup not in ("remove-if-unchanged", "manual"):
            die("request.isolation.cleanup must be remove-if-unchanged or manual")
        isolation["cleanup"] = cleanup
    if request["mutating"] and mode != "worktree":
        die("mutating wave requests require worktree isolation")
    request["isolation"] = isolation
    cookbook = request.get("cookbook")
    if cookbook is not None:
        if not isinstance(cookbook, dict):
            die("request.cookbook must be an object")
        validate_abs_path(cookbook.get("path"), "request.cookbook.path")
        cookbook_role = cookbook.get("role")
        if cookbook_role not in COOKBOOK_ROLES:
            die("request.cookbook.role must be a cookbook role")
        if cookbook_role != role:
            die("request.cookbook.role must match request.role")
        if "predicate_dir" in cookbook:
            validate_abs_path(cookbook.get("predicate_dir"), "request.cookbook.predicate_dir")
    return request


def read_frontier(args, request):
    frontier_file = args.frontier or os.environ.get("CODEX_MESH_BD_READY_FILE")
    if frontier_file:
        payload = load_json(frontier_file)
        source = "fixture"
    else:
        cmd = ["bd", "ready", "--parent", request["epic"], "--exclude-type", "epic", "--json"]
        completed = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)
        if completed.returncode != 0:
            die(completed.stderr.strip() or "bd ready frontier query failed")
        try:
            payload = json.loads(completed.stdout)
        except json.JSONDecodeError as exc:
            die(f"bd ready emitted invalid JSON: {exc}")
        source = "live-bd"
    if not isinstance(payload, list):
        die("frontier payload must be a JSON array")
    return payload, source


def normalize_task(raw, epic):
    if not isinstance(raw, dict):
        return None
    task_id = raw.get("id")
    if not isinstance(task_id, str) or not BEADS_ISSUE_RE.match(task_id):
        return None
    parent = raw.get("parent") or epic
    if parent != epic:
        return None
    title = raw.get("title") or task_id
    status = raw.get("status") or "open"
    out = {
        "id": task_id,
        "title": title,
        "status": status,
        "parent": parent,
    }
    if raw.get("assignee"):
        out["assignee"] = raw["assignee"]
    return out


def address_for(prefix, task_id):
    suffix = re.sub(r"[^a-z0-9-]+", "-", task_id.lower()).strip("-")
    address = f"{prefix}-{suffix}"
    if len(address) <= 64:
        return address
    digest = hashlib.sha1(task_id.encode("utf-8")).hexdigest()[:12]
    budget = 64 - len(digest) - 1
    return f"{address[:budget].rstrip('-')}-{digest}"


def render_message(template, request, task):
    return (
        template.replace("{{task}}", task["id"])
        .replace("{{epic}}", request["epic"])
        .replace("{{title}}", task["title"])
    )


def render_cookbook_message(request, task):
    cookbook = request.get("cookbook")
    if not cookbook:
        return render_message(request["message_template"], request, task), None
    cmd = [
        os.path.join(script_dir(), "codex-mesh-cookbook"),
        "render",
        "--json",
        "--cookbook",
        cookbook["path"],
        "--role",
        cookbook["role"],
        "--task",
        task["id"],
        "--title",
        task["title"],
    ]
    predicate_dir = cookbook.get("predicate_dir")
    if predicate_dir:
        predicate_path = os.path.join(predicate_dir, f"{task['id']}.json")
        if not os.path.exists(predicate_path):
            die(f"request.cookbook.predicate_dir missing task predicate: {predicate_path}")
        cmd.extend(["--predicate", predicate_path])
    completed = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)
    if completed.returncode != 0:
        die(completed.stderr.strip() or "cookbook render failed")
    try:
        rendered = json.loads(completed.stdout)
    except json.JSONDecodeError as exc:
        die(f"cookbook renderer emitted invalid JSON: {exc}")
    message = rendered.get("message")
    if not isinstance(message, str) or not message.startswith("/goal "):
        die("cookbook renderer emitted a non-goal message")
    evidence = {
        "record_type": "cookbook_dispatch_evidence",
        "renderer": "context-cookbook-renderer",
        "rendered_record_type": rendered.get("record_type"),
        "cookbook_path": cookbook["path"],
        "cookbook_id": rendered.get("cookbook_id"),
        "parent_task": rendered.get("parent_task"),
        "role": rendered.get("role"),
        "task": rendered.get("task"),
        "source_reads_only_before_dispatch": True,
        "preserve_transport_semantics": True,
    }
    return message, evidence


def parse_key_values(output):
    values = {}
    for line in output.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            values[key.strip()] = value.strip()
    return values


def spawn_task(request, task, address, message, cookbook_evidence=None):
    cmd = [
        os.path.join(script_dir(), "spawn"),
        "--addr",
        address,
        "--role",
        request["role"],
        "--task",
        task["id"],
        "--isolation",
        request["isolation"]["mode"],
    ]
    if request["isolation"]["mode"] == "worktree":
        cmd.extend(["--worktree-base", request["isolation"]["worktree_base"]])
    cmd.extend([
        request["workdir"],
        message,
    ])
    completed = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=False)
    if completed.returncode != 0:
        record = {
            "record_type": "dispatch_record",
            "task": task["id"],
            "address": address,
            "role": request["role"],
            "status": "skipped",
            "reason": "spawn-failed",
            "message": message,
        }
        if cookbook_evidence:
            record["cookbook"] = cookbook_evidence
        return record
    values = parse_key_values(completed.stdout)
    record = {
        "record_type": "dispatch_record",
        "task": task["id"],
        "address": address,
        "role": request["role"],
        "status": "spawned",
        "message": message,
        "session_id": values.get("codex_session") or values.get("window_id"),
    }
    if cookbook_evidence:
        record["cookbook"] = cookbook_evidence
    if values.get("codex_transcript"):
        record["transcript_path"] = values["codex_transcript"]
        record["attachment"] = {
            "record_type": "session_attachment",
            "task": task["id"],
            "session_id": record["session_id"],
            "address": address,
            "role": request["role"],
            "cwd": request["workdir"],
            "transcript_path": values["codex_transcript"],
            "category": "session-started",
            "occurred_at_unix": int(time.time()),
        }
    if values.get("codex_worktree"):
        record["worktree_path"] = values["codex_worktree"]
    return record


def plan_or_dispatch(args, request, task, index):
    address = address_for(request["address_prefix"], task["id"])
    message, cookbook_evidence = render_cookbook_message(request, task)
    worktree_path = None
    if request["isolation"]["mode"] == "worktree":
        worktree_path = os.path.join(request["isolation"]["worktree_base"].rstrip("/"), address)
    dry_run = request["dry_run"] or os.environ.get("CODEX_MESH_DRY_RUN") == "1" or args.command == "status"
    if dry_run:
        record = {
            "record_type": "dispatch_record",
            "task": task["id"],
            "address": address,
            "role": request["role"],
            "status": "planned",
            "message": message,
        }
        if worktree_path:
            record["worktree_path"] = worktree_path
        if cookbook_evidence:
            record["cookbook"] = cookbook_evidence
        return record
    return spawn_task(request, task, address, message, cookbook_evidence)


def build_status(args, request, frontier, source):
    normalized = [task for task in (normalize_task(raw, request["epic"]) for raw in frontier) if task is not None]
    records = []
    dispatchable_seen = 0
    remaining = 0

    for task in normalized:
        address = address_for(request["address_prefix"], task["id"])
        if task["status"] != "open":
            records.append({
                "record_type": "dispatch_record",
                "task": task["id"],
                "address": address,
                "role": request["role"],
                "status": "skipped",
                "reason": "not-ready",
            })
            continue
        if dispatchable_seen >= request["concurrency_cap"]:
            remaining += 1
            records.append({
                "record_type": "dispatch_record",
                "task": task["id"],
                "address": address,
                "role": request["role"],
                "status": "skipped",
                "reason": "cap-reached",
            })
            continue
        records.append(plan_or_dispatch(args, request, task, dispatchable_seen))
        dispatchable_seen += 1

    spawned_count = sum(1 for record in records if record["status"] in ("planned", "spawned"))
    skipped_count = sum(1 for record in records if record["status"] == "skipped")
    return {
        "record_type": "wave_status",
        "epic": request["epic"],
        "request": request,
        "frontier_command": FRONTIER_COMMAND,
        "frontier_source": source,
        "frontier": normalized,
        "spawned_count": spawned_count,
        "skipped_count": skipped_count,
        "frontier_remaining": remaining,
        "records": records,
    }


def run(args):
    request = validate_request(load_json(args.request_json))
    frontier, source = read_frontier(args, request)
    payload = build_status(args, request, frontier, source)
    json.dump(payload, sys.stdout, indent=2, sort_keys=True)
    print()


def main():
    parser = argparse.ArgumentParser(description="Dispatch codex-mesh waves over Beads ready frontiers")
    subparsers = parser.add_subparsers(dest="command", required=True)
    for command in ("dispatch", "status"):
        sub = subparsers.add_parser(command, description=f"{command} a codex-mesh wave")
        sub.add_argument("--frontier", help="JSON fixture for bd ready frontier")
        sub.add_argument("request_json", help="path to a #WaveRequest JSON file")
        sub.set_defaults(func=run)
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
